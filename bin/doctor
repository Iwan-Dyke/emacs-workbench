#!/usr/bin/env bash
set -u

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root" || exit 1

status=0

doom_bin=""
if command -v doom >/dev/null 2>&1; then
    doom_bin="$(command -v doom)"
elif [ -x "$HOME/.emacs.d/bin/doom" ]; then
    doom_bin="$HOME/.emacs.d/bin/doom"
fi

check_command() {
    local name="$1"

    if command -v "$name" >/dev/null 2>&1; then
        printf "ok  %s found\n" "$name"
    else
        printf "fail %s not found\n" "$name"
        status=1
    fi
}

check_optional_command() {
    local name="$1"

    if command -v "$name" >/dev/null 2>&1; then
        printf "ok  %s found\n" "$name"
    else
        printf "warn %s not found\n" "$name"
    fi
}

check_path() {
    local path="$1"

    if [ -e "$path" ]; then
        printf "ok  %s exists\n" "$path"
    else
        printf "fail %s missing\n" "$path"
        status=1
    fi
}

printf "Emacs Workbench doctor\n"
printf "\n"

check_command git
check_command emacs
check_command emacsclient
check_command cmake
check_command make
check_command gcc

check_optional_command codex
check_optional_command kiro
check_optional_command claude

# Nerd-icons font for treemacs/UI icons (installed by platform-tools)
if [ -f "$HOME/.local/share/fonts/NFM.ttf" ] || [ -f "$HOME/Library/Fonts/NFM.ttf" ]; then
    printf "ok  nerd-icons font installed\n"
else
    printf "warn nerd-icons font not found (M-x nerd-icons-install-fonts)\n"
fi

# Language servers (ADR 0017, ADR 0029)
check_optional_command pyright
check_optional_command gopls
check_optional_command terraform-ls
check_optional_command bash-language-server
check_optional_command yaml-language-server
check_optional_command docker-langserver
check_optional_command lua-language-server
check_optional_command sqls

# Formatters (ADR 0018)
check_optional_command ruff
check_optional_command gofmt
check_optional_command stylua
check_optional_command shfmt
check_optional_command yamlfmt
check_optional_command terraform

if [ -n "$doom_bin" ]; then
    printf "ok  doom found: %s\n" "$doom_bin"
else
    printf "fail doom command not found\n"
    status=1
fi

check_path ./doom
check_path ./doom/init.el
check_path ./doom/config.el
check_path ./doom/packages.el
check_path ./bin/install
check_path ./bin/sync
check_path ./bin/doctor
check_path ./bin/workbench

if [ -L "$HOME/.config/doom" ]; then
    printf "ok  ~/.config/doom is a symlink\n"
elif [ -e "$HOME/.config/doom" ]; then
    printf "warn ~/.config/doom exists but is not a symlink\n"
else
    printf "warn ~/.config/doom is not linked yet\n"
fi

printf "\n"

if [ "$status" -eq 0 ]; then
    printf "Doctor passed\n"
else
    printf "Doctor found problems\n"
fi

exit "$status"
