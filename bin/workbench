#!/usr/bin/env bash
set -u

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Optional machine-local environment (e.g. HiDPI display scaling). Untracked;
# see bin/workbench.local.example. Sourced before Emacs starts so GTK reads it.
if [ -f "$repo_root/bin/workbench.local" ]; then
    . "$repo_root/bin/workbench.local"
fi

command_name="start"

if [ "${1:-}" = "stop" ] || [ "${1:-}" = "restart" ]; then
    command_name="$1"
    shift
fi

profile="${1:-personal}"
server_name="workbench-$profile"

case "$profile" in
personal | work)
    ;;
*)
    printf "fail unknown profile: %s\n" "$profile"
    printf "usage: %s [personal|work] | stop [personal|work] | restart [personal|work]\n" "$0"
    exit 1
    ;;
esac

export WORKBENCH_PROFILE="$profile"

if ! command -v emacsclient >/dev/null 2>&1; then
    if [ "$command_name" != "start" ]; then
        printf "fail emacsclient not found\n"
        exit 1
    fi

    emacs
    exit "$?"
fi

stop_daemon() {
    emacsclient --socket-name "$server_name" --eval '(kill-emacs)' >/dev/null 2>&1
}

case "$command_name" in
start)
    emacsclient --socket-name "$server_name" --alternate-editor "" -c
    ;;
stop)
    stop_daemon || true
    ;;
restart)
    stop_daemon || true
    emacsclient --socket-name "$server_name" --alternate-editor "" -c
    ;;
esac
